{
  "name": "ai-agent-nodejs-lab",
  "version": "0.1.0",
  "private": true,
  "description": "A Node.js lab for building AI agent services with NestJS.",
  "license": "MIT",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "npm run test --workspaces --if-present",
    "eval:ticket": "ts-node apps/ai-ticket-classifier/scripts/run-prompt-stability-eval.ts",
    "test:watch": "npm run test:watch --workspace apps/ai-ticket-classifier",
    "start:local": "./scripts/start-local.sh",
    "start:dev": "npm run start:dev --workspace apps/ai-ticket-classifier",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.0",
    "@types/bluebird": "^3.5.42",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.15.2",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0"
  },
  "dependencies": {
    "bluebird": "^3.7.2",
    "lodash": "^4.18.1",
    "openai": "^6.34.0"
  }
}
