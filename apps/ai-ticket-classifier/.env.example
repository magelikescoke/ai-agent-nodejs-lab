PORT=3000

# Local development values. docker-compose overrides MONGODB_URI and REDIS_URL
# for the app container so it can reach the mongodb and redis services by name.
MONGODB_URI=mongodb://root:example@localhost:27017/ai_ticket_classifier?authSource=admin
REDIS_URL=redis://localhost:6379

TICKET_ANALYSIS_PROMPT_VERSION=ticket-analysis-v1

GLM_MODEL=GLM-4.7-Flash
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_TIMEOUT_MS=30000
