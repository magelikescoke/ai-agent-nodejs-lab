{
  "name": "ai-ticket-classifier",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS service for classifying support tickets with AI workflows.",
  "scripts": {
    "build": "cd ../.. && nest build ai-ticket-classifier",
    "start": "node ../../dist/apps/ai-ticket-classifier/main.js",
    "start:dev": "cd ../.. && nest start ai-ticket-classifier --watch",
    "start:debug": "cd ../.. && nest start ai-ticket-classifier --debug --watch",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --config jest.config.ts --watch",
    "test:cov": "jest --config jest.config.ts --coverage"
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.0",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "mongoose": "^9.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  }
}
